server:
  grpc:
    addr: ":8088"
    timeout: "30s"
  http:
    addr: ":9099"
    timeout: "60s"
    public_url: "http://localhost:9099"
    cors:
      allow_origins: ["http://graviton.local:9099"]  # set explicit origins; "*" is rejected when allow_credentials=true
      allow_methods: ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS"]
      allow_headers: ["Content-Type", "Authorization", "X-Api-Key", "X-Graviton-Project", "X-Request-Id", "X-Correlation-Id"]
      allow_credentials: true
      max_age: 3600
  metrics:
    addr: ":9100"

security:
  jwt:
    secret: ""              # env: GRAVITON_SECURITY_JWT_SECRET
    access_ttl: "15m"
    refresh_ttl: "7d"
  api_key:
    header: "x-api-key"

data:
  database:
    source: ""              # env: GRAVITON_DATA_DATABASE_SOURCE
    debug: true
    pool:
      max_idle_conns: 4
      max_open_conns: 16
      conn_max_lifetime: "1h"
      conn_max_idle_time: "30m"
  redis:
    addr: "127.0.0.1:6379"
    password: ""            # env: GRAVITON_DATA_REDIS_PASSWORD
    db: 0

storage:
  provider: "s3"            # or "minio" / "local"
  s3:
    endpoint: ""            # env: GRAVITON_STORAGE_S3_ENDPOINT
    region: "us-east-1"
    bucket: "Graviton-storage"
    access_key_id: ""       # env: GRAVITON_STORAGE_S3_ACCESS_KEY
    secret_access_key: ""   # env: GRAVITON_STORAGE_S3_SECRET_KEY
  local:
    path: "./data/files"

functions:
  executor: "docker"
  docker:
    host: "unix:///var/run/docker.sock"
    network: "Graviton-functions"
    registry: "Graviton-funcs"

telemetry:
  enabled: false
  otlp_endpoint: ""
  service_name: "Graviton"

messaging:
  smtp:
    host: ""                # env: GRAVITON_MESSAGING_SMTP_HOST
    port: 587
    username: ""
    password: ""            # env: GRAVITON_MESSAGING_SMTP_PASSWORD
    from: "noreply@graviton.local"
    use_tls: true
  dev_log_otp: true         # log OTP to stdout when SMTP host is empty (dev only)
  dev_log_sms: true         # log SMS OTP to stdout when SMS provider is empty (dev only)
  sms:
    provider: ""            # twilio
    twilio:
      account_sid: ""       # env: GRAVITON_MESSAGING_SMS_TWILIO_ACCOUNT_SID
      auth_token: ""        # env: GRAVITON_MESSAGING_SMS_TWILIO_AUTH_TOKEN
      from: ""

idgen:
  default_strategy: uuid    # uuid | ulid | snowflake | sequence | random (random reserved)
  random:
    length: 10              # reserved for future random strategy
    charset: numeric        # numeric | alphanumeric
  snowflake:
    node_id: 0                # env: GRAVITON_IDGEN_SNOWFLAKE_NODE_ID
  sequence:
    redis_key_prefix: Graviton:seq
  resources:
    users: uuid
    sessions: uuid
    documents: uuid
