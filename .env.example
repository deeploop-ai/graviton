# Database
ORIONID_DATA_DATABASE_SOURCE=postgres://orionid:orionid@127.0.0.1:5432/orionid?sslmode=disable

# Redis
ORIONID_DATA_REDIS_PASSWORD=

# JWT / Session
ORIONID_SECURITY_JWT_SECRET=change-me-in-production

# Object Storage (MinIO example)
ORIONID_STORAGE_S3_ENDPOINT=http://127.0.0.1:9000
ORIONID_STORAGE_S3_ACCESS_KEY_ID=minioadmin
ORIONID_STORAGE_S3_SECRET_ACCESS_KEY=minioadmin

# Compose local overrides
POSTGRES_USER=orionid
POSTGRES_PASSWORD=orionid
POSTGRES_DB=orionid
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
