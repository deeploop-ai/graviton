# Database
FLEET_DATA_DATABASE_SOURCE=postgres://fleet:fleet@127.0.0.1:5432/fleet?sslmode=disable

# Redis
FLEET_DATA_REDIS_PASSWORD=

# JWT / Session
FLEET_SECURITY_JWT_SECRET=change-me-in-production

# Object Storage (MinIO example)
FLEET_STORAGE_S3_ENDPOINT=http://127.0.0.1:9000
FLEET_STORAGE_S3_ACCESS_KEY_ID=minioadmin
FLEET_STORAGE_S3_SECRET_ACCESS_KEY=minioadmin

# Compose local overrides
POSTGRES_USER=fleet
POSTGRES_PASSWORD=fleet
POSTGRES_DB=fleet
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
