# Database
GRAVITON_DATA_DATABASE_SOURCE=postgres://graviton:graviton@127.0.0.1:5432/graviton?sslmode=disable

# Redis
GRAVITON_DATA_REDIS_PASSWORD=

# JWT / Session
GRAVITON_SECURITY_JWT_SECRET=change-me-in-production

# Object Storage (MinIO example)
GRAVITON_STORAGE_S3_ENDPOINT=http://127.0.0.1:9000
GRAVITON_STORAGE_S3_ACCESS_KEY_ID=minioadmin
GRAVITON_STORAGE_S3_SECRET_ACCESS_KEY=minioadmin

# Compose local overrides
POSTGRES_USER=graviton
POSTGRES_PASSWORD=graviton
POSTGRES_DB=graviton
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
